      "body": "\u062a\u0635\u0645\u064a\u0645 \u0648\u0628\u0646\u0627\u0621 \u0648\u0625\u062f\u0627\u0631\u0629 \u0645\u0646\u0635\u0627\u062a \u0648\u064a\u0628 \u0625\u0646\u062a\u0627\u062c\u064a\u0629 \u0645\u0646 \u0627\u0644\u0628\u062f\u0627\u064a\u0629 \u0625\u0644\u0649 \u0627\u0644\u0646\u0647\u0627\u064a\u0629 \u2014 \u0648\u0627\u062c\u0647\u0627\u062a Angular\u060c APIs Spring Boot\u060c PostgreSQL\u060c \u0648\u0627\u0644\u0628\u0646\u064a\u0629 \u0627\u0644\u062a\u062d\u062a\u064a\u0629 CI/CD \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 Docker \u0648 VPS. \u064a\u0648\u0645\u064a\u064b\u0627: GitLab CI\u060c Jenkins \u0648 Nginx."
    },
    {
      "when": "\u062c\u0627\u0631\u064d",
      "title": "\u0645\u0637\u0648\u0631 \u0645\u0633\u062a\u0642\u0644",
      "at": "\u0639\u0645\u0644 \u062d\u0631",
      "body": "\u062a\u0633\u0644\u064a\u0645 \u0645\u0646\u062a\u062c\u0627\u062a \u0648\u064a\u0628 \u0648\u0645\u0648\u0628\u0627\u064a\u0644 \u0644\u0644\u0639\u0645\u0644\u0627\u0621 \u0639\u0644\u0649 \u0645\u062c\u0645\u0648\u0639\u0629 MERN\u060c NestJS \u0648 AWS \u2014 \u0645\u0646 \u0627\u0644\u062a\u0637\u0648\u064a\u0631 \u0627\u0644\u062c\u062f\u064a\u062f \u0625\u0644\u0649 \u0627\u0644\u0628\u0646\u064a\u0629 \u0627\u0644\u062a\u062d\u062a\u064a\u0629 \u0648\u0627\u0644\u0646\u0634\u0631."
    }
  ],
  "contact": {
    "text": "\u0645\u0641\u062a\u0648\u062d \u0644\u0644\u0648\u0638\u0627\u0626\u0641 \u0628\u062f\u0648\u0627\u0645 \u0643\u0627\u0645\u0644 \u0648\u0623\u0639\u0645\u0627\u0644 \u062d\u0631\u0629. \u0623\u0633\u0631\u0639 \u0637\u0631\u064a\u0642\u0629 \u0644\u0644\u062a\u0648\u0627\u0635\u0644 \u0645\u0639\u064a \u0647\u064a \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a \u2014 \u0623\u0631\u062f \u062e\u0644\u0627\u0644 \u064a\u0648\u0645.",
