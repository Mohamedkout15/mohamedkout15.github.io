---
import Layout from "../../layouts/Layout.astro";
import { getTranslations, supportedLangs, langLabels } from "../../i18n";
import { profile } from "../../data/content";
import type { Lang } from "../../i18n";

export async function getStaticPaths() {
  return supportedLangs.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);
const currentLang = lang;

const credlyBadges = await fetch("https://www.credly.com/users/kout-mohamed/badges.json")
  .then((r) => r.json())
  .then((d) => d.data)
  .catch(() => []);
---

<Layout lang={currentLang} translations={t}>
  <!-- ============================================================ HERO -->
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">{t.hero.eyebrow}<span class="cursor"></span></p>
      <h1>Mohamed <span class="accent">Kout</span></h1>
      <p class="role">{t.hero.role}</p>
      <p class="lede" set:html={t.hero.lede}></p>

      <div class="sysblock" aria-label="summary">
        <div class="sysblock-bar">
          <span class="tdot r"></span><span class="tdot y"></span><span class="tdot g"></span>
          <span style="margin-left:.4rem">{t.hero.summaryTitle}</span>
        </div>
        <div class="sysblock-rows">
          {t.summary.map((s) => (
            <div class="sysrow">
              <span class="k">{s.k}</span>
              <span class="v">{s.hl ? <span class="hl">{s.v}</span> : s.v}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="cta-row">
        <a class="btn btn-primary" href="#projects">{t.cta.viewProjects} <span class="arrow">→</span></a>
        <a class="btn" href={`mailto:${profile.email}`}>{t.cta.getInTouch} <span class="arrow">→</span></a>
        <a class="btn" href={profile.cvUrl}>{t.cta.downloadCv} <span class="arrow">↓</span></a>
      </div>
    </div>
  </section>

  <!-- ========================================================== WHOAMI -->
  <section class="pane" id="about">
    <div class="wrap reveal">
      <p class="pane-label">{t.about.label}</p>
      <div class="prose">
        <p set:html={t.about.p1}></p>
        <p class="tdim" set:html={t.about.p2}></p>
      </div>
    </div>
  </section>

  <!-- =========================================================== STACK -->
  <section class="pane" id="stack">
    <div class="wrap reveal">
      <p class="pane-label">{t.sections.stack}</p>
      <div class="stack-grid">
        {t.stack.map((g) => (
          <div class="stack-group">
            <h3>{g.title}</h3>
            {g.items.map((it) => (
              <div class="stack-item">
                {it.name}<span class="lvl">{it.lvl}</span>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================================================== PROJECTS -->
  <section class="pane" id="projects">
    <div class="wrap reveal">
      <p class="pane-label">{t.sections.projects}</p>
      <div class="proj-list">
        {t.projects.items.map((p) => (
          <article class="proj">
            <div class="proj-head">
              <h3>{p.name}</h3>
              <span class={`tag ${p.live ? "live" : ""}`}>
                {p.live ? t.projects.live : p.tag}
              </span>
            </div>
            <p>{p.blurb}</p>
            <p style="margin-top:.6rem">{p.detail}</p>
            <div class="proj-stack">
              {p.stack.map((s) => <span class="chip">{s}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================================================== CERTIFICATIONS -->
  <section class="pane" id="certifications">
    <div class="wrap reveal">
      <p class="pane-label">{t.sections.certifications}</p>
      <div class="badge-grid">
        {credlyBadges.map((b) => (
          <a class="badge-card" href={b.badge_template.url} target="_blank" rel="noopener noreferrer">
            <img class="badge-img" src={b.image_url} alt={b.badge_template.name} loading="lazy" />
            <div class="badge-body">
              <span class="badge-name">{b.badge_template.name}</span>
              <span class="badge-issuer">{b.issuer.summary}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====================================================== EXPERIENCE -->
  <section class="pane" id="experience">
    <div class="wrap reveal">
      <p class="pane-label">{t.sections.experience}</p>
      <div class="exp">
        {t.experience.map((e) => (
          <div class="exp-item">
            <div class="exp-when">{e.when}</div>
            <div class="exp-body">
              <h3>{e.title} <span class="at">@ {e.at}</span></h3>
              <p>{e.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========================================================= CONTACT -->
  <section class="pane" id="contact">
    <div class="wrap reveal">
      <p class="pane-label">{t.sections.contact}</p>
      <div class="prose">
        <p>{t.contact.text}</p>
      </div>
      <div class="contact-grid">
        <a class="btn btn-primary" href={`mailto:${profile.email}`}>{profile.email} <span class="arrow">→</span></a>
        <a class="btn" href={profile.github}>{t.contact.github} <span class="arrow">→</span></a>
        <a class="btn" href={profile.linkedin}>{t.contact.linkedin} <span class="arrow">→</span></a>
      </div>
    </div>

    <div class="wrap">
      <footer class="foot">
        <span class="exit">{t.footer.exit}</span>
        <span>© {new Date().getFullYear()} {profile.name}</span>
        <span>{t.footer.credit}</span>
      </footer>
    </div>
  </section>
</Layout>
